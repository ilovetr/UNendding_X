# ─────────────────────────────────────────────
# 川流/UnendingX 生产环境配置
# 复制为 .env 后修改对应值
# ─────────────────────────────────────────────

# 数据库（PostgreSQL）
# 使用 Docker 内置 PostgreSQL 时：
POSTGRES_PASSWORD=CHANGE_ME_random_string_here

# 或使用外部 PostgreSQL（腾讯云数据库等）
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/unendingx
# DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host:5432/unendingx

# ─── 安全密钥（必填）───
# 生成方式: openssl rand -base64 64
SECRET_KEY=CHANGE_ME_to_random_64_char_string

# ─── 前端 ───
NEXT_PUBLIC_API_URL=http://81.70.187.125
FRONTEND_URL=http://81.70.187.125

# ─── AI 能力（可选）───
# 至少配置一个 LLM 提供商才能使用「AI 生成群组描述」功能

# OpenAI
# OPENAI_API_KEY=sk-xxx

# SiliconFlow（推荐国内使用）
# SILICONFLOW_API_KEY=xxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxx
