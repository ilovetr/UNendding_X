# AgentHub Backend - 环境变量示例
# 复制为 .env 后修改

# 必填：JWT 签名密钥（生产必须使用强随机值）
SECRET_KEY=change_me_to_a_strong_random_secret

# 数据库（开发用 SQLite，生产用 PostgreSQL）
DATABASE_URL=postgresql+asyncpg://agenthub:agenthub_secret@localhost:5432/agenthub
DATABASE_URL_SYNC=postgresql+psycopg2://agenthub:agenthub_secret@localhost:5432/agenthub

# 开发用 SQLite（注释掉上面两行后取消注释）
# DATABASE_URL=sqlite+aiosqlite:///./dev.db
# DATABASE_URL_SYNC=sqlite:///./dev.db

# JWT 配置
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS（逗号分隔，生产改为实际域名）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Agent 对外暴露地址（生产必填公网地址）
AGENT_ENDPOINT=http://localhost:8000
